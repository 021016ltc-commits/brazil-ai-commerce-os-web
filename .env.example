# Brazil AI Commerce OS Lite environment template

# Runtime mode: development | staging | production.
SYSTEM_MODE=development

# development/staging: sqlite is the default local real-data mode.
# production: postgres/Supabase should be used; test data is disabled by runtime guardrails.
DATA_SOURCE_MODE=sqlite
ALLOW_TEST_DATA=false

# Optional PostgreSQL/Supabase connection. If omitted or unavailable, the database adapter falls back to SQLite.
DATABASE_URL=

# Local SQLite database path. Relative paths resolve from the project root.
SQLITE_DB_PATH=./data/brazil_ai_commerce_os.db

# API response cache. CACHE_MODE supports memory | disabled.
CACHE_MODE=memory
CACHE_ENABLED=true
SCHEDULER_ENABLED=false
SERVER_INSTANCE_ID=
LOG_LEVEL=debug

# Optional read-only Shopee API proxy/base URL.
# If omitted, Shopee connector reads real local cache and returns an empty state when no data exists.
SHOPEE_MODE=readonly
SHOOPE_API_MODE=readonly
SHOPEE_API_MODE=readonly
SHOPEE_API_BASE_URL=
SHOPEE_OPEN_API_BASE_URL=https://partner.shopeemobile.com
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_CLIENT_ID=
SHOPEE_CLIENT_SECRET=
SHOPEE_ACCESS_TOKEN=
SHOPEE_REFRESH_TOKEN=
SHOPEE_SHOP_ID=
SHOPEE_SYNC_MODE=realtime
SHOPEE_API_KEY=
SHOPEE_SECRET=
SHOPEE_TOKEN_URL=
SHOPEE_REDIRECT_URL=
SHOPEE_TOKEN_ENCRYPTION_KEY=
SHOPEE_READONLY_API_BASE_URL=
SHOPEE_READONLY_ACCESS_TOKEN=

# Public app label. This is safe to expose in the browser.
NEXT_PUBLIC_APP_NAME=Brazil AI Commerce OS Lite
