# Brazil AI Commerce OS Lite environment template

# Runtime mode: development | staging | production.
SYSTEM_MODE=development

# development/staging: sqlite or mock are allowed.
# production: postgres/Supabase should be used; mock priority is disabled by runtime guardrails.
DATA_SOURCE_MODE=sqlite

# Optional PostgreSQL/Supabase connection. If omitted or unavailable, the database adapter falls back to SQLite.
DATABASE_URL=

# Local SQLite database path. Relative paths resolve from the project root.
SQLITE_DB_PATH=./data/brazil_ai_commerce_os.db

# API response cache. CACHE_MODE supports memory | disabled.
CACHE_MODE=memory
CACHE_ENABLED=true
SCHEDULER_ENABLED=false
SERVER_INSTANCE_ID=
LOG_LEVEL=debug

# Optional read-only Shopee API proxy/base URL.
# If omitted, Shopee connector reads SQLite cache, then mock fallback.
SHOPEE_MODE=mock
SHOOPE_API_MODE=mock
SHOPEE_API_MODE=mock
SHOPEE_API_BASE_URL=
SHOPEE_CLIENT_ID=
SHOPEE_CLIENT_SECRET=
SHOPEE_ACCESS_TOKEN=
SHOPEE_REFRESH_TOKEN=
SHOPEE_SHOP_ID=
SHOPEE_SYNC_MODE=realtime
SHOPEE_API_KEY=
SHOPEE_SECRET=
SHOPEE_TOKEN_URL=
SHOPEE_READONLY_API_BASE_URL=
SHOPEE_READONLY_ACCESS_TOKEN=

# Public app label. This is safe to expose in the browser.
NEXT_PUBLIC_APP_NAME=Brazil AI Commerce OS Lite
